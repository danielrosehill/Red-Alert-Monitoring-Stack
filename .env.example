# =============================================================================
# Red Alert Monitoring Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# =============================================================================

# -- Your Alerting Area [REQUIRED] -------------------------------------------
# Your local area name as it appears in Pikud HaOref alerts (Hebrew).
# This is used across the entire stack:
#   - Actuator: triggers direct-threat response (red lights + shelter TTS)
#   - Geodash: highlights your area on the map
#   - OSINT Notifier: Pushover alerts, intel reports, and sitreps
#   - Prompt Runner: auto-generates immediate intel on local alerts
#   - MCP Server: provides area context to AI agents
# Example: ירושלים - דרום
ALERT_AREA=

# -- Service Ports (all optional, shown with defaults) -----------------------
# Override any port to avoid conflicts with existing services on your host.
# OREF_PROXY_PORT=8764
# GEODASH_PORT=8083
# INFLUXDB_PORT=8086
# ACTUATOR_PORT=8782
# RSS_CACHE_PORT=8785
# MCP_SERVER_PORT=8786
# PROMPT_RUNNER_PORT=8787

# -- Oref Alert Proxy --------------------------------------------------------
# No configuration needed — polls Pikud HaOref automatically.
# Must run from an Israeli IP address.

# -- InfluxDB (Geodash time-series storage) ----------------------------------
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=redalert
INFLUXDB_BUCKET=alerts
INFLUXDB_TOKEN=redalert-dev-token
# INFLUXDB_ADMIN_USER=admin
# INFLUXDB_ADMIN_PASSWORD=redalert-admin

# -- OSINT Notifier [REQUIRED for push notifications] ------------------------
# Pushover credentials — get from https://pushover.net/
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Location targeting — set to your area for emergency-level alerts
LOCATION_NAME=Jerusalem
LOCAL_KEYWORDS_EN=jerusalem,central israel
LOCAL_KEYWORDS_HE=ירושלים,מרכז הארץ

# Telegram channels to monitor for missile launch reports
# TELEGRAM_CHANNEL_EN=manniefabian
# TELEGRAM_CHANNEL_HE=news0404il

# Oref volumetric alert thresholds (comma-separated area counts)
# OREF_AREA_THRESHOLDS=50,100,200,300,400,500,600,700,800,900,1000

# RSS feeds for news context in AI reports
# RSS_FEEDS=https://www.timesofisrael.com/feed/,https://www.jns.org/feed/

# -- AI / LLM Configuration --------------------------------------------------
# OpenRouter API key — used by OSINT notifier (dual-model sitrep), Prompt Runner
# Get one from https://openrouter.ai/
OPENROUTER_API_KEY=

# Groq API key — used by OSINT notifier (fast intel) and Prompt Runner
# Get one from https://console.groq.com/
# GROQ_API_KEY=

# OpenAI API key for generating TTS audio files (one-time setup)
# OPENAI_API_KEY=

# -- Scheduled SITREPs (Prompt Runner) ----------------------------------------
# Automatic SITREP generation on a schedule, delivered to Telegram and/or email.

# Schedule: comma-separated UTC hours (e.g. "0,6,18") or interval ("every:6").
# Leave empty to disable the built-in scheduler.
# SITREP_SCHEDULE=0,6,18

# Where to deliver scheduled SITREPs (comma-separated: telegram, email)
# SITREP_DELIVER_TO=telegram,email

# Resend API key for email delivery — get one from https://resend.com/
# RESEND_API_KEY=

# Sender address (must be verified in Resend, e.g. sitrep@yourdomain.com)
# SITREP_EMAIL_FROM=

# Recipient address(es), comma-separated
# SITREP_EMAIL_TO=

# -- Home Assistant (Actuator HA Bridge) [REQUIRED for actuation] -------------
# The actuator sets an input_select entity in HA to reflect alert state.
# HA automations then handle lights, sirens, TTS, etc.
# See ha/ directory for setup instructions and example automations.
HASS_HOST=
HASS_TOKEN=
# HASS_ENTITY=input_select.red_alert_state

# -- Snapcast (for management UI client listing, optional) --------------------
# SNAPCAST_SERVER=10.0.0.4
# SNAPCAST_PORT=1780

# -- Mosquitto MQTT Broker (only used in compose/with-broker.yml) -------------
# Default config works out of the box. Customize if needed:
# MQTT_EXTERNAL_PORT=1883

# -- RSS Feeds ----------------------------------------------------------------
# Up to 10 feeds, numbered 1-10. Defaults to Times of Israel + JNS if unset.
RSS_FEED_1_URL=https://www.timesofisrael.com/feed/
RSS_FEED_1_NAME=Times of Israel
RSS_FEED_2_URL=https://www.jns.org/feed/
RSS_FEED_2_NAME=JNS
# RSS_FEED_3_URL=
# RSS_FEED_3_NAME=

# RSS poll interval in seconds (default: 300 = 5 minutes)
# RSS_POLL_INTERVAL=300

# -- Geopolitical Simulation (Management UI) -----------------------------------
# Gemini API key for search-grounded intelligence gathering in the simulation pipeline.
# Get one from https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# -- Google Drive Upload (Management UI) ---------------------------------------
# Upload simulation PDFs to Google Drive via a service account.
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Drive API
# 3. Download the JSON key file
# 4. Share a Drive folder with the service account email
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json
# GOOGLE_DRIVE_FOLDER_ID=

# -- Management UI Port -------------------------------------------------------
# MANAGEMENT_UI_PORT=8888

# -- Home Assistant MCP --------------------------------------------------------
# For .mcp.json — connect AI agents to your Home Assistant instance
# HA_MCP_URL=http://10.0.0.4:8123/mcp
# HA_ACCESS_TOKEN=

