# =============================================================================
# Red Alert Monitoring Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# =============================================================================

# -- Your Alerting Area [REQUIRED] -------------------------------------------
# Your local area name as it appears in Pikud HaOref alerts (Hebrew).
# This is used across the entire stack:
#   - Actuator: triggers direct-threat response (red lights + shelter TTS)
#   - Geodash: highlights your area on the map
#   - OSINT Notifier: Pushover alerts, intel reports, and sitreps
#   - Prompt Runner: auto-generates immediate intel on local alerts
#   - MCP Server: provides area context to AI agents
# Example: ירושלים - דרום
ALERT_AREA=

# -- Service Ports (all optional, shown with defaults) -----------------------
# Override any port to avoid conflicts with existing services on your host.
# OREF_PROXY_PORT=8764
# GEODASH_PORT=8083
# POSTGRES_PORT=5432
# ACTUATOR_PORT=8782
# RSS_CACHE_PORT=8785
# MCP_SERVER_PORT=8786
# PROMPT_RUNNER_PORT=8787

# Polling interval for alert-consuming services (seconds, default: 3)
# POLL_INTERVAL=3

# -- Network URLs (for Management UI) ----------------------------------------
# Used to construct webhook endpoints and display URLs in the management console.
# LAN_URL=http://10.0.0.4
# WAN_URL=https://redalert.example.com

# -- Oref Alert Proxy --------------------------------------------------------
# No configuration needed — polls Pikud HaOref automatically.
# Must run from an Israeli IP address.

# -- TimescaleDB / Postgres (unified storage) --------------------------------
# Single connection string used by geodash, api, and (in PR 2) actuator.
# Replaces the previous InfluxDB + SQLite split.
POSTGRES_URL=postgresql://redalert:redalert-dev-password@timescaledb:5432/redalert
# POSTGRES_USER=redalert
# POSTGRES_PASSWORD=redalert-dev-password
# POSTGRES_DB=redalert

# -- Legacy InfluxDB (only set these if running the migration script) --------
# Required by scripts/migrate_influx_to_pg.py to read from the old database.
# Leave unset once migration is complete.
# INFLUXDB_URL=http://influxdb:8086
# INFLUXDB_ORG=redalert
# INFLUXDB_BUCKET=alerts
# INFLUXDB_TOKEN=redalert-dev-token

# -- Pushover Notifications [REQUIRED for push notifications] ----------------
# Pushover credentials — get from https://pushover.net/
# Threshold-crossing notifications are handled by the actuator service.
PUSHOVER_API_TOKEN=
# Comma-separated for multiple recipients (e.g. key1,key2)
PUSHOVER_USER_KEY=

# Location targeting — set to your area for emergency-level alerts
LOCATION_NAME=Jerusalem
LOCAL_KEYWORDS_EN=jerusalem,central israel
LOCAL_KEYWORDS_HE=ירושלים,מרכז הארץ

# Telegram channels to monitor for missile launch reports
# TELEGRAM_CHANNEL_EN=manniefabian
# TELEGRAM_CHANNEL_HE=news0404il

# Oref volumetric alert thresholds (comma-separated area counts)
# OREF_AREA_THRESHOLDS=50,100,200,300,400,500,600,700,800,900,1000

# RSS feeds for news context in AI reports
# RSS_FEEDS=https://www.timesofisrael.com/feed/,https://www.jns.org/feed/

# -- Telegram Bot -------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to interact with the bot (empty = open)
# ALLOWED_TELEGRAM_USERS=

# LLM models for Telegram bot (defaults shown — override to use different models)
# SITREP_MODEL=google/gemini-3-flash-preview
# CHAT_MODEL=google/gemini-3.1-flash-lite-preview
# TTS_MODEL=openai/gpt-audio-mini

# -- Tavily (news search for AI sitreps) -------------------------------------
# TAVILY_API_KEY=

# -- AI / LLM Configuration --------------------------------------------------
# OpenRouter API key — used by OSINT notifier (dual-model sitrep), Prompt Runner
# Get one from https://openrouter.ai/
OPENROUTER_API_KEY=

# Groq API key — used by OSINT notifier (fast intel) and Prompt Runner
# Get one from https://console.groq.com/
# GROQ_API_KEY=

# OpenAI API key for generating TTS audio files (one-time setup)
# OPENAI_API_KEY=

# -- Scheduled SITREPs (Prompt Runner) ----------------------------------------
# Automatic SITREP generation on a schedule, delivered to Telegram and/or email.

# Schedule: comma-separated UTC hours (e.g. "0,6,18") or interval ("every:6").
# Leave empty to disable the built-in scheduler.
# SITREP_SCHEDULE=0,6,18

# Where to deliver scheduled SITREPs (comma-separated: telegram, email)
# SITREP_DELIVER_TO=telegram,email

# Resend API key for email delivery — get one from https://resend.com/
# RESEND_API_KEY=

# Sender address (must be verified in Resend, e.g. sitrep@yourdomain.com)
# SITREP_EMAIL_FROM=

# Recipient address(es), comma-separated
# SITREP_EMAIL_TO=

# -- Home Assistant (Actuator HA Bridge) [REQUIRED for actuation] -------------
# The actuator sets an input_select entity in HA to reflect alert state.
# HA automations then handle lights, sirens, TTS, etc.
# See ha/ directory for setup instructions and example automations.
HASS_HOST=
HASS_TOKEN=
# HASS_ENTITY=input_select.red_alert_state

# When to trigger the prompt runner for immediate intel on local alerts.
# "active" = only on active red alert (default)
# "warning" = only on alerts expected
# "both" = on either warning or active
# PROMPT_RUNNER_TRIGGER=active
# INTEL_COOLDOWN=600              # Seconds between immediate intel reports (default 600 = 10 min)

# -- Snapcast TTS Announcements ------------------------------------------------
# Plays TTS alerts through Snapcast speaker groups on alert state changes.
# Requires a TCP source in your Snapcast server config (snapserver.conf):
#   source = tcp://0.0.0.0:4953?name=RedAlert&sampleformat=48000:16:2&mode=server
#
# SNAPCAST_SERVER=10.0.0.3
# SNAPCAST_PORT=1780
# SNAPCAST_STREAM_PORT=4953
# SNAPCAST_GROUP=                   # Target group name (empty = default group)
# SNAPCAST_VOLUME=50                 # Announcement volume 0-100 (restored after)
# SNAPCAST_TTS_PORT=8783
# TTS_VOICE=en-US-GuyNeural         # edge-tts voice (see: edge-tts --list-voices)
# TTS_ON_WARNING=true                # Announce early warnings
# TTS_ON_ACTIVE=true                 # Announce active red alerts
# TTS_ON_CLEAR=true                  # Announce all-clear
# TTS_ON_THRESHOLD=true              # Announce nationwide thresholds

# -- Geodash Alert Persistence -------------------------------------------------
# How long alerts are presumed active without an all-clear (seconds)
# PRESUMED_ACTIVE_DURATION=1800
# PREWARNING_ACTIVE_DURATION=300

# -- Webhook Notifications -----------------------------------------------------
# HTTP POST payloads on all alert events (localized + threshold crossings).
# Configure one or more destination URLs (comma-separated).
# WEBHOOK_URLS=https://example.com/hook1,https://n8n.local/webhook/red-alert
# WEBHOOK_PORT=8784
#
# Optional HMAC-SHA256 signing secret (sent as X-Webhook-Signature header)
# WEBHOOK_SECRET=
#
# Delivery timeout in seconds (default: 10)
# WEBHOOK_TIMEOUT=10

# -- SMS Relay (Twilio) -------------------------------------------------------
# SMS and automated voice call notifications via Twilio.
# Great for sheltering in low-signal environments where push notifications
# may not arrive, but SMS and voice calls still get through.
#
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890
# SMS_RECIPIENTS=+972501234567,+972509876543
# SMS_RELAY_PORT=8792
#
# Delivery mode: "sms" (text only), "voice" (calls only), "both" (default)
# TWILIO_DELIVERY_MODE=both
#
# Automated voice call on all-clear — rings recipients to let them know
# the event is over so they can leave the protected space.
# TWILIO_VOICE_ON_CLEAR=true
# TWILIO_VOICE_MESSAGE=Hi, this is your Red Alert system calling. Good news. The alert for your area is over. You are all clear to leave the protected space. Stay safe!
#
# Nationwide escalation SMS when alert count crosses thresholds
# ESCALATION_ENABLED=false

# -- MQTT Sirens (Zigbee TS0601 / NEO NAS-AB02B2) ----------------------------
# Direct siren control via MQTT — bypasses Home Assistant entirely.
# Publishes Zigbee2MQTT payloads to activate/silence sirens on alert events.
#
# MQTT broker connection
# MQTT_BROKER=10.0.0.4
# MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_SIREN_PORT=8789
#
# Siren topics per alert state (comma-separated zigbee2mqtt set topics).
# You can use the same topics for all states or different sirens per state.
# Topic format: zigbee2mqtt/<friendly-name>/set
#
# Topics to activate on early warning (category 14):
# MQTT_SIREN_TOPICS_WARNING=zigbee2mqtt/office_siren/set
#
# Topics to activate on red alert (categories 1-12):
# MQTT_SIREN_TOPICS_ACTIVE=zigbee2mqtt/office_siren/set,zigbee2mqtt/bedroom_siren/set
#
# Topics to send all-clear / stop (category 13 or area drops):
# MQTT_SIREN_TOPICS_CLEAR=zigbee2mqtt/office_siren/set,zigbee2mqtt/bedroom_siren/set
#
# Custom payloads (JSON) — override defaults for your specific siren model.
# Defaults are designed for TS0601 (NEO NAS-AB02B2):
#   Warning: {"warning":{"mode":"emergency","level":"medium","strobe":true,"duration":60}}
#   Active:  {"warning":{"mode":"emergency","level":"high","strobe":true,"duration":120}}
#   Clear:   {"warning":{"mode":"stop"}}
# MQTT_SIREN_PAYLOAD_WARNING=
# MQTT_SIREN_PAYLOAD_ACTIVE=
# MQTT_SIREN_PAYLOAD_CLEAR=
#
# Also sound sirens on nationwide threshold crossings (default: false)
# MQTT_SIREN_ON_THRESHOLD=false

# -- RSS Feeds ----------------------------------------------------------------
# Up to 10 feeds, numbered 1-10. Defaults to Times of Israel + JNS if unset.
RSS_FEED_1_URL=https://www.timesofisrael.com/feed/
RSS_FEED_1_NAME=Times of Israel
RSS_FEED_2_URL=https://www.jns.org/feed/
RSS_FEED_2_NAME=JNS
# RSS_FEED_3_URL=
# RSS_FEED_3_NAME=

# RSS poll interval in seconds (default: 300 = 5 minutes)
# RSS_POLL_INTERVAL=300

# -- Geopolitical Simulation (Management UI) -----------------------------------
# Gemini API key for search-grounded intelligence gathering in the simulation pipeline.
# Get one from https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# -- Google Drive Upload (Management UI) ---------------------------------------
# Upload simulation PDFs to Google Drive via a service account.
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Drive API
# 3. Download the JSON key file
# 4. Share a Drive folder with the service account email
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json
# GOOGLE_DRIVE_SITREP_FOLDER_ID=
# GOOGLE_DRIVE_FORECAST_FOLDER_ID=

# -- PDF Save Directories (Management UI) --------------------------------------
# Where SITREPs and simulation reports are saved as PDFs.
# These directories are inside the management-ui container's /app/data volume.
# Defaults are /app/data/sitreps and /app/data/simulations.
# SITREP_SAVE_DIR=/app/data/sitreps
# SIMULATION_SAVE_DIR=/app/data/simulations

# -- Unified API Port ----------------------------------------------------------
# API_PORT=8890

# -- Management UI Port -------------------------------------------------------
# MANAGEMENT_UI_PORT=8888

# -- Home Assistant MCP --------------------------------------------------------
# For .mcp.json — connect AI agents to your Home Assistant instance
# HA_MCP_URL=http://10.0.0.4:8123/mcp
# HA_ACCESS_TOKEN=

