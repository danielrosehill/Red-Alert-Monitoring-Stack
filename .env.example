# =============================================================================
# Red Alert Monitoring Stack — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
# =============================================================================

# -- Docker Hub (only needed if pushing custom images) ------------------------
# DOCKERHUB_USERNAME=your-username
# DOCKERHUB_TOKEN=your-access-token

# -- Oref Alert Proxy --------------------------------------------------------
# No configuration needed — polls Pikud HaOref automatically.
# Must run from an Israeli IP address.

# -- Geodash Dashboard -------------------------------------------------------
# URL where Geodash can reach the proxy (Docker internal network)
OREF_PROXY_URL=http://oref-proxy:8764

# InfluxDB configuration for Geodash time-series storage
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=redalert
INFLUXDB_BUCKET=alerts
INFLUXDB_TOKEN=redalert-dev-token

# -- Pushover Notifier [REQUIRED for push notifications] ---------------------
# Get these from https://pushover.net/
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Alert thresholds (comma-separated area counts that trigger a push)
# PUSHOVER_THRESHOLDS=50,100,200,500,1000

# -- Telegram Bot [REQUIRED for Telegram integration] ------------------------
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# OpenRouter API key for AI situation reports (optional but recommended)
# Get one from https://openrouter.ai/
OPENROUTER_API_KEY=

# -- Actuator (TTS + Smart Lights) -------------------------------------------
# MQTT broker address
# - If using docker-compose.with-broker.yml (bundled Mosquitto): set to "mosquitto"
# - If using an external broker on your LAN: set to its IP, e.g. "10.0.0.4"
MQTT_BROKER=
MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=

# Comma-separated MQTT topics for smart light control
# MQTT_LIGHT_TOPICS=zigbee2mqtt/living_room/set,zigbee2mqtt/bedroom/set

# Your local area name as it appears in Pikud HaOref alerts (Hebrew)
# This triggers the "direct threat" response (red lights + shelter announcement)
# LOCAL_AREA=

# -- Snapcast TTS (required by Actuator) -------------------------------------
# Path to Snapcast FIFO pipe on the host
# SNAPCAST_FIFO=/tmp/snapfifo

# OpenAI API key for generating TTS audio files (one-time setup)
# OPENAI_API_KEY=

# -- Mosquitto MQTT Broker (only used in docker-compose.with-broker.yml) -----
# Default config works out of the box. Customize if needed:
# MQTT_EXTERNAL_PORT=1883

# -- Management UI ------------------------------------------------------------
# STACK_NAME=Red Alert Monitoring Stack
# GEODASH_EXTERNAL_URL=http://localhost:8083
# PORTAINER_EXTERNAL_URL=http://localhost:9000

# -- Portainer ----------------------------------------------------------------
# No env vars needed — configure via web UI on first launch at :9000
