# ── Pushover (required) ──────────────────────────────────────────────────────
PUSHOVER_APP_TOKEN=
PUSHOVER_GROUP_KEY=

# ── Telegram Channels ────────────────────────────────────────────────────────
# English channel — military correspondent reporting missile launches
TELEGRAM_CHANNEL_EN=manniefabian
# Hebrew channel — Israeli news reporting launches
TELEGRAM_CHANNEL_HE=news0404il
# Poll interval in seconds
TELEGRAM_POLL_INTERVAL=15

# ── Location Targeting ───────────────────────────────────────────────────────
# Your location name (used in alert titles and intel prompts)
LOCATION_NAME=Jerusalem
# Comma-separated English keywords — if any appear in a launch report,
# the alert is elevated to high priority and AI reports are triggered
LOCAL_KEYWORDS_EN=jerusalem,central israel
# Comma-separated Hebrew keywords for the same purpose
LOCAL_KEYWORDS_HE=ירושלים,מרכז הארץ

# Examples for other locations:
# LOCATION_NAME=Tel Aviv
# LOCAL_KEYWORDS_EN=tel aviv,gush dan,central israel
# LOCAL_KEYWORDS_HE=תל אביב,גוש דן,מרכז הארץ
#
# LOCATION_NAME=Haifa
# LOCAL_KEYWORDS_EN=haifa,haifa bay,northern israel
# LOCAL_KEYWORDS_HE=חיפה,מפרץ חיפה,צפון הארץ
#
# LOCATION_NAME=Beer Sheva
# LOCAL_KEYWORDS_EN=beer sheva,beersheba,negev,southern israel
# LOCAL_KEYWORDS_HE=באר שבע,נגב,דרום הארץ

# ── Oref Volumetric Alerts ───────────────────────────────────────────────────
# Set to false to disable Oref monitoring
OREF_ENABLED=true
# URL of the Oref Alert Proxy (use host.docker.internal in Docker)
OREF_PROXY_URL=http://host.docker.internal:8764/api/alerts
OREF_POLL_INTERVAL=3
# Comma-separated area count thresholds that trigger notifications
OREF_AREA_THRESHOLDS=50,100,200,300,400,500,600,700,800,900,1000

# ── RSS News Context ─────────────────────────────────────────────────────────
# Comma-separated RSS feed URLs — headlines are fetched and injected into
# intel and sitrep prompts for real-time news context
RSS_FEEDS=https://www.timesofisrael.com/feed/,https://www.jns.org/feed/
# Maximum headlines to include per report
RSS_MAX_ITEMS=15

# ── OpenRouter (optional, single key for all AI features) ───────────────────
# Enables both immediate intel reports and dual-model sitreps on local events
# Get a key from https://openrouter.ai/
OPENROUTER_API_KEY=
# Minimum seconds between intel reports (default: 600 = 10 min)
INTEL_COOLDOWN=600
# Override models if desired:
# INTEL_MODEL=meta-llama/llama-4-scout
# SITREP_MODEL_A=google/gemini-3-flash-preview
# SITREP_MODEL_B=x-ai/grok-4.1-fast
# SITREP_SYNTHESIS_MODEL=google/gemini-3-flash-preview
